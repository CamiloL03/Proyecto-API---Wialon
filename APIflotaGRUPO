# 3. MOTOR DE LEY DE TRÁNSITO Y NLP
# ==========================================
class RulesEngine:
    @staticmethod
    def inferir_limite(calle: str) -> int:
        texto = str(calle).lower().strip()
        if re.search(r'\b(ruta|rn\d*|rp\d*|autopista|au\.|panamericana|acceso)\b', texto): return 110
        elif re.search(r'\b(avenida|av\.|av|blvd|boulevard)\b', texto): return 60
        else: return 40

    @staticmethod
    def procesar_infracciones(dfs_dict: dict, config: dict, current_target_name: str):
        df_inf = pd.DataFrame()
        col_loc = col_vel = col_cond = col_unidad_wialon = None
        
        # 1. Identificar tabla principal de Infracciones
        for label, df in dfs_dict.items():
            c_loc = next((col for col in df.columns if 'localización' in col.lower() or 'calle' in col.lower()), None)
            c_vel = next((col for col in df.columns if 'velocidad' in col.lower() or 'máx' in col.lower()), None)
            if c_loc and c_vel and not df.empty:
                df_inf = df.copy()
                col_loc, col_vel = c_loc, c_vel
                col_cond = next((col for col in df.columns if 'conductor' in col.lower() or 'chofer' in col.lower()), None)
                col_unidad_wialon = next((col for col in df.columns if 'unidad' in col.lower() or 'vehículo' in col.lower() or 'vehiculo' in col.lower()), None)
                break

        if df_inf.empty or not col_loc or not col_vel:
            return pd.DataFrame(), []

        # 2. Estandarizar Unidad y Conductor en df_inf
        if col_unidad_wialon:
            df_inf.rename(columns={col_unidad_wialon: 'Unidad'}, inplace=True)
        else:
            df_inf['Unidad'] = current_target_name # Fallback si procesamos unit by unit
            
        if col_cond:
            df_inf.rename(columns={col_cond: 'Conductor'}, inplace=True)
            df_inf['Conductor'] = df_inf['Conductor'].replace(r'^\s*[-]*\s*$', 'Sin identificar', regex=True).fillna('Sin identificar')
        else:
            df_inf['Conductor'] = "Sin asignar (Falta columna)"

        # 3. Procesamiento de velocidades y severidad
        extracted_vel = df_inf[col_vel].astype(str).str.extract(r'(\d+[\.,]?\d*)')[0]
        df_inf['Vel. Registrada'] = extracted_vel.str.replace(',', '.').astype(float).round(0).astype(int)
        df_inf['Límite Art. 51'] = df_inf[col_loc].apply(RulesEngine.inferir_limite).astype(int)
        df_inf['Exceso_KM'] = (df_inf['Vel. Registrada'] - df_inf['Límite Art. 51']).astype(int)
        
        conditions = [
            (df_inf['Exceso_KM'] >= config['leve_min']) & (df_inf['Exceso_KM'] < config['medio_min']),
            (df_inf['Exceso_KM'] >= config['medio_min']) & (df_inf['Exceso_KM'] < config['grave_min']),
            (df_inf['Exceso_KM'] >= config['grave_min'])
        ]
        df_inf['Severidad'] = np.select(conditions, ['Leve', 'Media', 'Grave'], default='OK')

        # 4. Identificar tabla de Métricas Operativas
        def parse_time(val):
            val = str(val).strip()
            if ':' in val:
                parts = val.split(':')
                try:
                    if len(parts) == 3: return int(parts[0]) + int(parts[1])/60 + int(parts[2])/3600
                    elif len(parts) == 2: return int(parts[0]) + int(parts[1])/60
                except: return 0.0
            num = re.search(r'(\d+[\.,]?\d*)', val)
            return float(num.group(1).replace(',', '.')) if num else 0.0

        df_metricas = None
        for label, df in dfs_dict.items():
            if 'motor' in label.lower() or 'estadística' in label.lower() or 'resumen' in label.lower():
                df_metricas = df.copy()
                break
                
        if df_metricas is None: df_metricas = df_inf.copy()

        c_cond_met = next((col for col in df_metricas.columns if 'conductor' in col.lower() or 'chofer' in col.lower()), None)
        c_unidad_met = next((col for col in df_metricas.columns if 'unidad' in col.lower() or 'vehículo' in col.lower() or 'vehiculo' in col.lower()), None)
        c_hm = next((col for col in df_metricas.columns if 'motor' in col.lower() or 'horas' in col.lower()), None)
        c_km = next((col for col in df_metricas.columns if 'kilometraje' in col.lower() or 'km' in col.lower() or 'distancia' in col.lower()), None)

        if c_cond_met:
            df_metricas['Conductor_Met'] = df_metricas[c_cond_met].replace(r'^\s*[-]*\s*$', 'Sin identificar', regex=True).fillna('Sin identificar')
        if c_unidad_met:
            df_metricas['Unidad_Met'] = df_metricas[c_unidad_met]
        else:
            df_metricas['Unidad_Met'] = current_target_name

        # 5. Agrupación y Cálculo RSV por Unidad y Conductor
        stats_rsv_list = []
        
        unidades_unicas = df_inf['Unidad'].unique().tolist()
        
        for unidad in unidades_unicas:
            df_unidad_inf = df_inf[df_inf['Unidad'] == unidad]
            df_unidad_met = df_metricas[df_metricas['Unidad_Met'] == unidad] if 'Unidad_Met' in df_metricas.columns else df_metricas

            conductores_inf = df_unidad_inf['Conductor'].unique().tolist()
            conductores_met = df_unidad_met['Conductor_Met'].unique().tolist() if 'Conductor_Met' in df_unidad_met.columns else []
            todos_conductores = set(conductores_inf + conductores_met)
            if not todos_conductores: todos_conductores = ["Sin identificar"]

            for driver in todos_conductores:
                df_driver_inf = df_unidad_inf[df_unidad_inf['Conductor'] == driver]
                leves = len(df_driver_inf[df_driver_inf['Severidad'] == 'Leve'])
                medias = len(df_driver_inf[df_driver_inf['Severidad'] == 'Media'])
                graves = len(df_driver_inf[df_driver_inf['Severidad'] == 'Grave'])
                
                if 'Conductor_Met' in df_unidad_met.columns:
                    df_driver_met = df_unidad_met[df_unidad_met['Conductor_Met'] == driver]
                else:
                    df_driver_met = df_unidad_met 

                total_hm = df_driver_met[c_hm].apply(parse_time).sum() if c_hm and not df_driver_met.empty else 0.0
                total_km = 0.0
                if c_km and not df_driver_met.empty:
                    km_str = df_driver_met[c_km].astype(str).str.extract(r'(\d+[\.,]?\d*)')[0]
                    total_km = km_str.str.replace(',', '.').astype(float).sum()

                hm_calc = total_hm if total_hm > 0 else 1.0 
                scoring = (leves * 1) + (medias * 1.5) + (graves * 2)
                icm = round(scoring / hm_calc, 2)

                if icm < 2.0: perfil = "Seguro (Verde)"
                elif icm < 5.0: perfil = "Preventivo (Amarillo)"
                elif icm < 8.0: perfil = "Riesgoso (Naranja)"
                else: perfil = "Inaceptable (Rojo)"

                if total_hm > 0 or total_km > 0 or len(df_driver_inf) > 0:
                    stats_rsv_list.append({
                        "Unidad": unidad,
                        "Conductor": driver,
                        "Infracciones Leves": leves,
                        "Infracciones Medias": medias,
                        "Infracciones Altas": graves,
                        "Horas Motor": round(total_hm, 2),
                        "Kilometraje Total": round(total_km, 2),
                        "Total Scoring": scoring,
                        "Puntaje ICM": icm,
                        "Perfil Conductor": perfil
                    })

        # 6. Preparar DataFrame de detalle visual
        df_infracciones_filtradas = df_inf[df_inf['Severidad'] != 'OK'].copy()
        if not df_infracciones_filtradas.empty:
            cols = df_infracciones_filtradas.columns.tolist()
            if 'Unidad' in cols:
                cols.insert(0, cols.pop(cols.index('Unidad')))
            if 'Conductor' in cols:
                cols.insert(1, cols.pop(cols.index('Conductor')))
            df_infracciones_filtradas = df_infracciones_filtradas[cols]
            
        return df_infracciones_filtradas, stats_rsv_list

