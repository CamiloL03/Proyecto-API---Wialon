class WialonExtractor:
    def __init__(self, token: str):
        self.token = token
        self.eid = None
        
        # Configuración de resiliencia de red (Evita caídas por microcortes o NameResolutionError)
        self.session = requests.Session()
        retries = Retry(total=5, backoff_factor=1, status_forcelist=[ 500, 502, 503, 504 ])
        self.session.mount('https://', HTTPAdapter(max_retries=retries))
        
    def login(self) -> str:
        res = self.session.get(WIALON_BASE_URL, params={"svc": "token/login", "params": json.dumps({"token": self.token})}).json()
        if "error" in res: raise ValueError(f"Falla en autenticación Wialon. Código: {res['error']}")
        self.eid = res["eid"]
        return self.eid

    def get_all_units(self) -> dict:
        spec = {"spec": {"itemsType": "avl_unit", "propName": "sys_name", "propValueMask": "*", "sortType": "sys_name"}, "force": 1, "flags": 1, "from": 0, "to": 0}
        res = self.session.get(WIALON_BASE_URL, params={"svc": "core/search_items", "params": json.dumps(spec), "sid": self.eid}).json()
        return {item['id']: item['nm'] for item in res.get('items', [])}

    def get_all_unit_groups(self) -> dict:
        spec = {"spec": {"itemsType": "avl_unit_group", "propName": "sys_name", "propValueMask": "*", "sortType": "sys_name"}, "force": 1, "flags": 1, "from": 0, "to": 0}
        res = self.session.get(WIALON_BASE_URL, params={"svc": "core/search_items", "params": json.dumps(spec), "sid": self.eid}).json()
        return {item['id']: item['nm'] for item in res.get('items', [])}

    def get_report_templates(self) -> dict:
        spec = {"spec": {"itemsType": "avl_resource", "propType": "propitemname", "propName": "reporttemplates", "propValueMask": "*", "sortType": "sys_name"}, "force": 1, "flags": 8193, "from": 0, "to": 0}
        res = self.session.get(WIALON_BASE_URL, params={"svc": "core/search_items", "params": json.dumps(spec), "sid": self.eid}).json()
        templates = {}
        for resource in res.get('items', []):
            res_id = resource['id']
            for rep_id, rep_data in resource.get('rep', {}).items():
                templates[f"{resource['nm']} - {rep_data['n']}"] = (res_id, int(rep_id))
        return templates

    def execute_and_download_report(self, res_id: int, tmpl_id: int, target_id: int, start_ts: int, end_ts: int) -> dict:
        self.session.get(WIALON_BASE_URL, params={"svc": "report/cleanup_result", "params": "{}", "sid": self.eid})
        exec_params = {"reportResourceId": res_id, "reportTemplateId": tmpl_id, "reportObjectId": target_id, "reportObjectSecId": 0, "interval": {"from": start_ts, "to": end_ts, "flags": 0}}
        res = self.session.get(WIALON_BASE_URL, params={"svc": "report/exec_report", "params": json.dumps(exec_params), "sid": self.eid}).json()
        
        if "error" in res: raise RuntimeError(f"Error ejecutando reporte. Código Wialon: {res['error']}")
        
        tables = res.get('reportResult', {}).get('tables', [])
        result_dfs = {}
        
        for index, table in enumerate(tables):
            table_name = table.get('label', f'Tabla_{index}')
            headers = table.get('header', [])
            rows_count = table.get('rows', 0)
            level = table.get('level', 1)
            
            if rows_count == 0:
                result_dfs[table_name] = pd.DataFrame(columns=headers)
                continue
            
            if level > 1:
                row_params = {"tableIndex": index, "config": {"type": "range", "data": {"from": 0, "to": rows_count - 1, "level": 10}}}
                res_rows = self.session.get(WIALON_BASE_URL, params={"svc": "report/select_result_rows", "params": json.dumps(row_params), "sid": self.eid}).json()
            else:
                row_params = {"tableIndex": index, "indexFrom": 0, "indexTo": rows_count - 1}
                res_rows = self.session.get(WIALON_BASE_URL, params={"svc": "report/get_result_rows", "params": json.dumps(row_params), "sid": self.eid}).json()
                
            data = []
            def extract_rows(rows_list):
                for row in rows_list:
                    if 'r' in row and isinstance(row['r'], list) and len(row['r']) > 0: extract_rows(row['r'])
                    else:
                        row_data = []
                        for cell in row.get('c', []):
                            val = cell.get('t', cell.get('v', '')) if isinstance(cell, dict) else cell
                            row_data.append(str(val))
                        data.append(row_data)

            extract_rows(res_rows)
            result_dfs[table_name] = pd.DataFrame(data, columns=headers)
            
        return result_dfs

